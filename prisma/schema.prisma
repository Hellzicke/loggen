generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LogMessage {
  id          Int             @id @default(autoincrement())
  title       String          @default("")
  message     String
  author      String
  version     String
  pinned      Boolean         @default(false)
  archived    Boolean         @default(false)
  archivedAt  DateTime?
  unpinnedAt  DateTime?
  imageUrl    String?
  createdAt   DateTime        @default(now())
  signatures  ReadSignature[]
  comments    Comment[]
  reactions   Reaction[]
  attachments LogAttachment[]
}

model LogAttachment {
  id           Int        @id @default(autoincrement())
  logId        Int
  log          LogMessage @relation(fields: [logId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime   @default(now())

  @@index([logId])
}

model Reaction {
  id        Int        @id @default(autoincrement())
  emoji     String
  logId     Int
  log       LogMessage @relation(fields: [logId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
}

model ReadSignature {
  id        Int        @id @default(autoincrement())
  name      String
  logId     Int
  log       LogMessage @relation(fields: [logId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([logId, name])
}

model Comment {
  id        Int        @id @default(autoincrement())
  message   String
  author    String
  deleted   Boolean    @default(false)
  logId     Int
  log       LogMessage @relation(fields: [logId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  createdAt DateTime   @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Meeting {
  id          Int            @id @default(autoincrement())
  title       String
  scheduledAt DateTime
  archived    Boolean        @default(false)
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  points      MeetingPoint[]
}

model MeetingPoint {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @default("")
  author      String
  completed   Boolean  @default(false)
  completedAt DateTime?
  notes       String?  @default("")
  meetingId   Int
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Suggestion {
  id          Int                 @id @default(autoincrement())
  title       String
  description String
  author      String
  category    String              @default("övrigt")
  status      String              @default("open")
  decision    String?
  decidedBy   String?
  decidedAt   DateTime?
  lockedAt    DateTime?
  archived    Boolean             @default(false)
  archivedAt  DateTime?
  createdAt   DateTime            @default(now())
  votes       SuggestionVote[]
  comments    SuggestionComment[]
}

model SuggestionVote {
  id           Int        @id @default(autoincrement())
  name         String
  suggestionId Int
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([suggestionId, name])
  @@index([suggestionId])
}

model SuggestionComment {
  id           Int                 @id @default(autoincrement())
  message      String
  author       String
  suggestionId Int
  suggestion   Suggestion          @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  parentId     Int?
  parent       SuggestionComment?  @relation("SuggestionCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      SuggestionComment[] @relation("SuggestionCommentReplies")
  createdAt    DateTime            @default(now())

  @@index([suggestionId])
}

